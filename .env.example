# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONTROL_TOPIC=etl.control
KAFKA_GROUP_ID=etl-runner
# Optional SASL/SSL
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Elasticsearch
ES_HOSTS=http://localhost:9200
# Pick one auth style:
# ES_USERNAME=elastic
# ES_PASSWORD=changeme
# ES_API_KEY=
ES_JOB_INDEX=etl-jobs

# Pagination (point-in-time + search_after)
PAGE_SIZE=1000
PIT_KEEP_ALIVE=5m

# Retry knobs
RETRY_MAX_ATTEMPTS=5
RETRY_BACKOFF_BASE=1.0
RETRY_BACKOFF_CAP=30.0
RETRY_JITTER=0.25

# Local staging
CSV_OUTPUT_DIR=/tmp/etl-csv

# Diagnostics (optional). When set, each job tees its raw extracted hits to
# <ES_RAW_DUMP_DIR>/<job_id>.ndjson as they stream. Unset = disabled.
# ES_RAW_DUMP_DIR=/tmp/etl-raw

# SFTP
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=etl
SFTP_KEY_PATH=/home/etl/.ssh/id_ed25519
SFTP_REMOTE_DIR=/incoming
SFTP_KNOWN_HOSTS=/home/etl/.ssh/known_hosts

# Logging
LOG_LEVEL=INFO
